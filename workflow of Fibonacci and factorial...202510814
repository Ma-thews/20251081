<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Factorial & Fibonacci Flowchart</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #0d0d1a;
    font-family: 'Space Mono', monospace;
    min-height: 100vh;
    padding: 30px 20px 60px;
    background-image:
      radial-gradient(ellipse at 15% 10%, rgba(0,229,255,0.07) 0%, transparent 45%),
      radial-gradient(ellipse at 85% 90%, rgba(255,107,107,0.07) 0%, transparent 45%);
  }
  h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    text-align: center;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
    background: linear-gradient(135deg, #00e5ff, #ff6b6b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .subtitle {
    text-align: center;
    color: #5555aa;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 36px;
  }
  .charts-wrapper {
    display: flex;
    gap: 60px;
    justify-content: center;
    align-items: flex-start;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
  }
  .chart-container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .chart-label {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 18px;
    padding: 8px 28px;
    border-radius: 4px;
  }
  .chart-label.fact { color: #00e5ff; border: 1px solid #00e5ff; box-shadow: 0 0 18px rgba(0,229,255,0.2); }
  .chart-label.fib  { color: #ff6b6b; border: 1px solid #ff6b6b; box-shadow: 0 0 18px rgba(255,107,107,0.2); }

  svg text { font-family: 'Space Mono', monospace; }

  .legend {
    display: flex;
    justify-content: center;
    gap: 28px;
    flex-wrap: wrap;
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid #1e1e3a;
    font-size: 0.68rem;
    color: #5555aa;
  }
  .legend-item { display: flex; align-items: center; gap: 8px; }
  .leg-rect { width: 18px; height: 12px; border-radius: 6px; }
  .leg-diamond {
    width: 14px; height: 14px;
    transform: rotate(45deg);
    border: 2px solid #5555aa;
  }
  .leg-oval { width: 20px; height: 12px; border-radius: 10px; background: #1e1e3a; border: 1px solid #5555aa; }
</style>
</head>
<body>

<h1>Factorial &amp; Fibonacci</h1>
<p class="subtitle">Recursive Workflow Diagrams</p>

<div class="charts-wrapper">

  <!-- ══════════ FACTORIAL SVG ══════════ -->
  <div class="chart-container">
    <div class="chart-label fact">Factorial</div>
    <svg width="320" height="780" viewBox="0 0 320 780">
      <defs>
        <marker id="arrowF" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="#00e5ff" opacity="0.8"/>
        </marker>
        <marker id="arrowFyes" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="#4ade80"/>
        </marker>
        <marker id="arrowFno" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="#f87171"/>
        </marker>
        <filter id="glowF">
          <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
          <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>

      <!-- START pill -->
      <rect x="95" y="10" width="130" height="38" rx="19" fill="#1a1a2e" stroke="#00e5ff" stroke-width="1.5" filter="url(#glowF)"/>
      <text x="160" y="34" text-anchor="middle" fill="#00e5ff" font-size="13" font-weight="700">START</text>

      <!-- Arrow START→INPUT -->
      <line x1="160" y1="48" x2="160" y2="83" stroke="#00e5ff" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowF)"/>

      <!-- INPUT box -->
      <rect x="80" y="85" width="160" height="44" rx="6" fill="#12122a" stroke="#00e5ff" stroke-width="1.2"/>
      <text x="160" y="104" text-anchor="middle" fill="#c0c0e0" font-size="11">Input:</text>
      <text x="160" y="120" text-anchor="middle" fill="#00e5ff" font-size="13" font-weight="700">n</text>

      <!-- Arrow INPUT→Decision1 -->
      <line x1="160" y1="129" x2="160" y2="164" stroke="#00e5ff" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowF)"/>

      <!-- Decision 1: n < 0 -->
      <polygon points="160,165 230,205 160,245 90,205" fill="#12122a" stroke="#f87171" stroke-width="1.5"/>
      <text x="160" y="200" text-anchor="middle" fill="#f5f5ff" font-size="11">n &lt; 0 ?</text>
      <text x="160" y="216" text-anchor="middle" fill="#f5f5ff" font-size="10">(negative?)</text>

      <!-- YES branch left: n<0 → Error -->
      <line x1="90" y1="205" x2="30" y2="205" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrowFyes)"/>
      <text x="58" y="198" text-anchor="middle" fill="#4ade80" font-size="10" font-weight="700">YES</text>
      <!-- Error box -->
      <rect x="2" y="218" width="82" height="44" rx="6" fill="#2a1020" stroke="#f87171" stroke-width="1.2"/>
      <text x="43" y="237" text-anchor="middle" fill="#f87171" font-size="10">Return</text>
      <text x="43" y="252" text-anchor="middle" fill="#f87171" font-size="10">"Error"</text>

      <!-- NO branch down -->
      <line x1="160" y1="245" x2="160" y2="275" stroke="#f87171" stroke-width="1.5" marker-end="url(#arrowFno)"/>
      <text x="170" y="263" fill="#f87171" font-size="10" font-weight="700">NO</text>

      <!-- Decision 2: base case -->
      <polygon points="160,277 240,322 160,367 80,322" fill="#12122a" stroke="#facc15" stroke-width="1.5"/>
      <text x="160" y="314" text-anchor="middle" fill="#f5f5ff" font-size="10">n==0 or</text>
      <text x="160" y="328" text-anchor="middle" fill="#f5f5ff" font-size="10">n==1 ?</text>

      <!-- YES branch right: base case → Return 1 -->
      <line x1="240" y1="322" x2="295" y2="322" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrowFyes)"/>
      <text x="265" y="315" text-anchor="middle" fill="#4ade80" font-size="10" font-weight="700">YES</text>
      <!-- Return 1 box -->
      <rect x="256" y="336" width="60" height="40" rx="6" fill="#0d2a1a" stroke="#4ade80" stroke-width="1.2"/>
      <text x="286" y="353" text-anchor="middle" fill="#4ade80" font-size="10">Return</text>
      <text x="286" y="367" text-anchor="middle" fill="#4ade80" font-size="12" font-weight="700">1</text>

      <!-- NO branch down: recurse -->
      <line x1="160" y1="367" x2="160" y2="400" stroke="#f87171" stroke-width="1.5" marker-end="url(#arrowFno)"/>
      <text x="170" y="387" fill="#f87171" font-size="10" font-weight="700">NO</text>

      <!-- Recurse box -->
      <rect x="65" y="402" width="190" height="50" rx="6" fill="#12122a" stroke="#00e5ff" stroke-width="1.5"/>
      <text x="160" y="422" text-anchor="middle" fill="#c0c0e0" font-size="10">Return</text>
      <text x="160" y="440" text-anchor="middle" fill="#00e5ff" font-size="12" font-weight="700">n × factorial(n−1)</text>

      <!-- Recurse label -->
      <text x="160" y="468" text-anchor="middle" fill="#5555aa" font-size="10">🔁 calls itself with n−1</text>

      <!-- Arrow recurse→Print -->
      <line x1="160" y1="472" x2="160" y2="505" stroke="#00e5ff" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowF)"/>

      <!-- Print box -->
      <rect x="80" y="507" width="160" height="44" rx="6" fill="#12122a" stroke="#00e5ff" stroke-width="1.2"/>
      <text x="160" y="526" text-anchor="middle" fill="#c0c0e0" font-size="11">Print</text>
      <text x="160" y="542" text-anchor="middle" fill="#00e5ff" font-size="12" font-weight="700">Result</text>

      <!-- Arrow Print→END -->
      <line x1="160" y1="551" x2="160" y2="585" stroke="#00e5ff" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowF)"/>

      <!-- END pill -->
      <rect x="95" y="587" width="130" height="38" rx="19" fill="#1a1a2e" stroke="#00e5ff" stroke-width="1.5" filter="url(#glowF)"/>
      <text x="160" y="611" text-anchor="middle" fill="#00e5ff" font-size="13" font-weight="700">END</text>

      <!-- Connect YES Return 1 back down to Print via curve -->
      <path d="M286 376 Q286 490 240 524" fill="none" stroke="#4ade80" stroke-width="1.2" stroke-dasharray="5,3" marker-end="url(#arrowFyes)"/>
    </svg>
  </div>

  <!-- ══════════ FIBONACCI SVG ══════════ -->
  <div class="chart-container">
    <div class="chart-label fib">Fibonacci</div>
    <svg width="340" height="900" viewBox="0 0 340 900">
      <defs>
        <marker id="arrowB" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="#ff6b6b" opacity="0.8"/>
        </marker>
        <marker id="arrowByes" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="#4ade80"/>
        </marker>
        <marker id="arrowBno" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="#f87171"/>
        </marker>
        <filter id="glowB">
          <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
          <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>

      <!-- START pill -->
      <rect x="105" y="10" width="130" height="38" rx="19" fill="#1a1a2e" stroke="#ff6b6b" stroke-width="1.5" filter="url(#glowB)"/>
      <text x="170" y="34" text-anchor="middle" fill="#ff6b6b" font-size="13" font-weight="700">START</text>

      <!-- Arrow START→INPUT -->
      <line x1="170" y1="48" x2="170" y2="83" stroke="#ff6b6b" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowB)"/>

      <!-- INPUT box -->
      <rect x="90" y="85" width="160" height="44" rx="6" fill="#1a1215" stroke="#ff6b6b" stroke-width="1.2"/>
      <text x="170" y="104" text-anchor="middle" fill="#c0c0e0" font-size="11">Input:</text>
      <text x="170" y="120" text-anchor="middle" fill="#ff6b6b" font-size="13" font-weight="700">n</text>

      <!-- Arrow INPUT→D1 -->
      <line x1="170" y1="129" x2="170" y2="164" stroke="#ff6b6b" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowB)"/>

      <!-- Decision 1: n < 0 -->
      <polygon points="170,165 250,205 170,245 90,205" fill="#1a1215" stroke="#f87171" stroke-width="1.5"/>
      <text x="170" y="200" text-anchor="middle" fill="#f5f5ff" font-size="11">n &lt; 0 ?</text>
      <text x="170" y="216" text-anchor="middle" fill="#f5f5ff" font-size="10">(negative?)</text>

      <!-- YES left: Error -->
      <line x1="90" y1="205" x2="28" y2="205" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrowByes)"/>
      <text x="57" y="198" text-anchor="middle" fill="#4ade80" font-size="10" font-weight="700">YES</text>
      <rect x="2" y="218" width="72" height="44" rx="6" fill="#2a1020" stroke="#f87171" stroke-width="1.2"/>
      <text x="38" y="237" text-anchor="middle" fill="#f87171" font-size="10">Return</text>
      <text x="38" y="252" text-anchor="middle" fill="#f87171" font-size="10">"Error"</text>

      <!-- NO down -->
      <line x1="170" y1="245" x2="170" y2="280" stroke="#f87171" stroke-width="1.5" marker-end="url(#arrowBno)"/>
      <text x="180" y="266" fill="#f87171" font-size="10" font-weight="700">NO</text>

      <!-- Decision 2: n == 0 -->
      <polygon points="170,282 250,322 170,362 90,322" fill="#1a1215" stroke="#facc15" stroke-width="1.5"/>
      <text x="170" y="316" text-anchor="middle" fill="#f5f5ff" font-size="11">n == 0 ?</text>

      <!-- YES right: Return 0 -->
      <line x1="250" y1="322" x2="308" y2="322" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrowByes)"/>
      <text x="277" y="315" text-anchor="middle" fill="#4ade80" font-size="10" font-weight="700">YES</text>
      <rect x="272" y="336" width="62" height="40" rx="6" fill="#0d2a1a" stroke="#4ade80" stroke-width="1.2"/>
      <text x="303" y="353" text-anchor="middle" fill="#4ade80" font-size="10">Return</text>
      <text x="303" y="367" text-anchor="middle" fill="#4ade80" font-size="12" font-weight="700">0</text>

      <!-- NO down -->
      <line x1="170" y1="362" x2="170" y2="397" stroke="#f87171" stroke-width="1.5" marker-end="url(#arrowBno)"/>
      <text x="180" y="383" fill="#f87171" font-size="10" font-weight="700">NO</text>

      <!-- Decision 3: n == 1 -->
      <polygon points="170,399 250,439 170,479 90,439" fill="#1a1215" stroke="#facc15" stroke-width="1.5"/>
      <text x="170" y="433" text-anchor="middle" fill="#f5f5ff" font-size="11">n == 1 ?</text>

      <!-- YES right: Return 1 -->
      <line x1="250" y1="439" x2="308" y2="439" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrowByes)"/>
      <text x="277" y="432" text-anchor="middle" fill="#4ade80" font-size="10" font-weight="700">YES</text>
      <rect x="272" y="453" width="62" height="40" rx="6" fill="#0d2a1a" stroke="#4ade80" stroke-width="1.2"/>
      <text x="303" y="470" text-anchor="middle" fill="#4ade80" font-size="10">Return</text>
      <text x="303" y="484" text-anchor="middle" fill="#4ade80" font-size="12" font-weight="700">1</text>

      <!-- NO down -->
      <line x1="170" y1="479" x2="170" y2="514" stroke="#f87171" stroke-width="1.5" marker-end="url(#arrowBno)"/>
      <text x="180" y="500" fill="#f87171" font-size="10" font-weight="700">NO</text>

      <!-- Recurse box -->
      <rect x="55" y="516" width="230" height="56" rx="6" fill="#1a1215" stroke="#ff6b6b" stroke-width="1.5"/>
      <text x="170" y="536" text-anchor="middle" fill="#c0c0e0" font-size="10">Return</text>
      <text x="170" y="554" text-anchor="middle" fill="#ff6b6b" font-size="11" font-weight="700">fib(n−1) + fib(n−2)</text>
      <text x="170" y="582" text-anchor="middle" fill="#5555aa" font-size="10">🔁 two recursive calls</text>

      <!-- Arrow recurse→Print -->
      <line x1="170" y1="586" x2="170" y2="618" stroke="#ff6b6b" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowB)"/>

      <!-- Print box -->
      <rect x="90" y="620" width="160" height="44" rx="6" fill="#1a1215" stroke="#ff6b6b" stroke-width="1.2"/>
      <text x="170" y="639" text-anchor="middle" fill="#c0c0e0" font-size="11">Print</text>
      <text x="170" y="655" text-anchor="middle" fill="#ff6b6b" font-size="12" font-weight="700">Result</text>

      <!-- Arrow Print→END -->
      <line x1="170" y1="664" x2="170" y2="698" stroke="#ff6b6b" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowB)"/>

      <!-- END pill -->
      <rect x="105" y="700" width="130" height="38" rx="19" fill="#1a1215" stroke="#ff6b6b" stroke-width="1.5" filter="url(#glowB)"/>
      <text x="170" y="724" text-anchor="middle" fill="#ff6b6b" font-size="13" font-weight="700">END</text>

      <!-- Dashed return paths from YES boxes back to Print -->
      <path d="M303 493 Q330 580 248 638" fill="none" stroke="#4ade80" stroke-width="1.2" stroke-dasharray="5,3" marker-end="url(#arrowByes)"/>
      <path d="M303 376 Q335 480 330 580 Q330 640 250 640" fill="none" stroke="#4ade80" stroke-width="1.2" stroke-dasharray="5,3" marker-end="url(#arrowByes)"/>
    </svg>
  </div>

</div>

<!-- Legend -->
<div class="legend">
  <div class="legend-item">
    <div class="leg-rect" style="background:#1a1a2e;border:1.5px solid #00e5ff;border-radius:12px;"></div>
    Terminal (Start/End)
  </div>
  <div class="legend-item">
    <div class="leg-rect" style="background:#12122a;border:1.5px solid #6666aa;"></div>
    Process
  </div>
  <div class="legend-item">
    <svg width="18" height="16" viewBox="0 0 24 20">
      <polygon points="12,1 23,10 12,19 1,10" fill="#12122a" stroke="#facc15" stroke-width="2"/>
    </svg>
    Decision
  </div>
  <div class="legend-item">
    <div class="leg-rect" style="background:#0d2a1a;border:1.5px solid #4ade80;"></div>
    Base Case Result
  </div>
  <div class="legend-item">
    <div class="leg-rect" style="background:#2a1020;border:1.5px solid #f87171;"></div>
    Error
  </div>
  <div class="legend-item">
    <svg width="30" height="10"><line x1="0" y1="5" x2="22" y2="5" stroke="#4ade80" stroke-width="1.5" stroke-dasharray="4,2"/><polygon points="22,1 30,5 22,9" fill="#4ade80"/></svg>
    Return path
  </div>
</div>

</body>
</html>
